<theme>

  <formatVersion>4</formatVersion>

  <!-- =====================
       Background Image
       ===================== -->
  <view name="system, basic, detailed, grid">
    <image name="background" extra="true">
      <path>./_inc/images/bg_bokeh.jpg</path>
      <origin>0 0</origin>
      <pos>0 0</pos>
      <size>1 1</size>
    </image>
  </view>

  <view name="video">
    <image name="background">
      <path>./_inc/images/bg_bokeh.png</path>
      <origin>0 0</origin>
      <pos>0 0</pos>
      <size>1 1</size>
    </image>
    <image name="md_marquee">
      <pos>0.84 0.74</pos>
      <origin>0.55 0.5</origin>
      <maxSize>0.156 0.95</maxSize>
      <color>104474F0</color>
      <zIndex>40</zIndex>
    </image>
  </view>

  <!-- =====================
       Layer + Helpsystem
       ===================== -->
  <view name="system, basic, detailed, grid, video">
    <image name="background_system_image" extra="true">
      <origin>0 0</origin>
      <pos>0 0</pos>
      <size>1 1</size>
    </image>

    <image name="background_help" extra="true">
      <path>./_inc/images/bg_helpbar.png</path>
      <origin>0 1</origin>
      <pos>0 1</pos>
      <size>1 0.10</size>
    </image>

    <helpsystem name="help">
      <textColor>ffffff</textColor>
      <iconColor>cccccc</iconColor>
      <fontPath>./_inc/fonts/NESCyrillic_gamelist.ttf</fontPath>
      <pos>0.045 -1</pos>
    </helpsystem>
  </view>

  <!-- Capa superior fija -->
  <image name="background" extra="true">
    <origin>0 0</origin>
    <pos>0.045 0.070005</pos>
    <size>1 1</size>
    <path>./_inc/images/main1.png</path>
    <zIndex>100</zIndex>
  </image>

  <view name="system"></view>

  <!-- =====================
       SYSTEM VIEW + CAROUSEL
       ===================== -->
  <feature supported="carousel">
    <view name="system">

      <carousel name="systemcarousel">
        <type>horizontal</type>
        <color>00000000</color>
        <logoScale>1</logoScale>
        <pos>-0.0 0.3</pos>
        <size>1.0 0.4</size>
        <logoSize>0.1916666666666667 0.3703703703703704</logoSize>
        <maxLogoCount>5</maxLogoCount>
        <zIndex>101</zIndex>
      </carousel>

      <!-- Fondo principal del layout -->
      <image name="background" extra="true">
        <origin>0 0</origin>
        <pos>0 0</pos>
        <size>1 1</size>
        <path>./_inc/images/main1.png</path>
        <zIndex>90</zIndex>
      </image>

      <!-- Help -->
     <image name="background2" extra="true">
        <origin>0 0</origin>
    	<pos>0.35 0.06</pos>
    	<maxSize>0.29 0.29</maxSize>
    	<path>./_inc/images/system_help.png</path>
    	<zIndex>100</zIndex>
	</image>

      <!-- Logo sistema -->
      <image name="background3" extra="true">
   			 <origin>0 1</origin>   <!-- Origen en la parte inferior izquierda -->
   			 <pos>0.07 0.96</pos>     <!-- Posición más a la izquierda (0.05) y manteniendo la altura (0.7) -->
   			 <maxSize>0.15 0.079</maxSize>    <!-- Tamaño pequeño -->
   			 <path>./_inc/logos/${system.theme}.svg</path>  <!-- Ruta del logo -->
   			 <zIndex>100</zIndex>    <!-- Asegura que se muestra encima de otros elementos -->
			</image>

      <text name="systemInfo">
        <backgroundColor>00000000</backgroundColor>
        <color>FFFFFF</color>
        <fontPath>./_inc/fonts/NESCyrillic_gamelist.ttf</fontPath>
        <fontSize>0.0592592592592593</fontSize>
        <pos>0.00 0.2322222222222222</pos>
        <size>1 0.050</size>
        <zIndex>102</zIndex>
      </text>

      <image name="carousel_bar" extra="true">
        <path>./_inc/images/carousel_bar.png</path>
        <origin>0.5 0</origin>
        <size>0 0.4814814814814815</size>
        <pos>0.5 0.2185185185185185</pos>
        <zIndex>100</zIndex>
      </image>

    </view>
  </feature>

  <!-- =====================
       BASIC / DETAILED / VIDEO / GRID
       ===================== -->
  <view name="basic, detailed, video, grid">

    <image name="logo_background" extra="true">
      <path>./_inc/images/bg_systembar.png</path>
      <origin>0 0</origin>
      <pos>0 0</pos>
      <size>1 0.10</size>
    </image>

    <image name="gamelist_deco" extra="true">
      <origin>0 0</origin>
      <pos>0 0</pos>
      <size>1 1</size>
      <path>./_inc/images/main2.png</path>
      <zIndex>09</zIndex>
    </image>

    <image name="logo">
      <origin>0 0.66</origin>
      <pos>0.0001 0.065</pos>
      <maxSize>0.10 0.10</maxSize>
    </image>

  </view>

  <!-- BASIC VIEW -->
  <view name="basic">
    <textlist name="gamelist">
      <selectorColor>ffffff</selectorColor>
      <selectedColor>373737</selectedColor>
      <primaryColor>ffffff</primaryColor>
      <secondaryColor>08304f</secondaryColor>
      <fontPath>./_inc/fonts/NESCyrillic_gamelist.ttf</fontPath>
      <fontSize>0.035</fontSize>
      <alignment>left</alignment>
      <size>0.50 0.102</size>
      <pos>0.04 0.10</pos>
    </textlist>
  </view>

  <!-- Navigation sounds -->
  <feature supported="navigationsounds">
    <view name="all">
      <sound name="systembrowse"><path>./_inc/audio/systembrowse.wav</path></sound>
      <sound name="quicksysselect"><path>./_inc/audio/quicksysselect.wav</path></sound>
      <sound name="select"><path>./_inc/audio/select.wav</path></sound>
      <sound name="back"><path>./_inc/audio/back.wav</path></sound>
      <sound name="scroll"><path>./_inc/audio/scroll.wav</path></sound>
      <sound name="favorite"><path>./_inc/audio/favorite.wav</path></sound>
      <sound name="launch"><path>./_inc/audio/launch.wav</path></sound>
    </view>
  </feature>

  <!-- DETAILED / VIDEO VIEW -->
  <view name="detailed, video">

    <image name="no_image_bg" extra="true">
      <origin>0.5 0.5</origin>
      <pos>0.19 0.225</pos>
      <maxSize>0.30 0.25</maxSize>
      <path>./_inc/images/bg_no_game_image.png</path>
      <zIndex>20</zIndex>
    </image>

    <image name="meta_bg_top" extra="true">
      <path>./_inc/images/bg_metabar_top.png</path>
      <origin>0 0</origin>
      <pos>0.36 0.10</pos>
      <size>0.58 0.09</size>
      <zIndex>100</zIndex>
    </image>

    <image name="meta_bg_bottom" extra="true">
      <path>./_inc/images/bg_metabar_bottom.png</path>
      <origin>0 0</origin>
      <pos>0.36 0.19</pos>
      <size>0.58 0.14</size>
      <zIndex>100</zIndex>
    </image>

    <image name="description_bg_outline, media_bg_outline" extra="true">
      <origin>0 0</origin>
      <path>./_inc/images/bg_color.png</path>
      <color>06162444</color>
      <zIndex>100</zIndex>
    </image>

    <image name="description_bg, media_bg" extra="true">
      <origin>0 0</origin>
      <path>./_inc/images/bg_color.png</path>
      <color>46505C9F</color>
      <zIndex>100</zIndex>
    </image>

    <image name="description_bg_outline" extra="true">
      <pos>0.36 0.34</pos>
      <size>0.362 0.542</size>
      <zIndex>100</zIndex>
    </image>

    <image name="description_bg" extra="true">
      <pos>0.361 0.341</pos>
      <size>0.36 0.54</size>
      <zIndex>100</zIndex>
    </image>

    <image name="media_bg_outline" extra="true">
      <pos>0.742 0.34</pos>
      <size>0.198 0.542</size>
      <zIndex>100</zIndex>
    </image>

    <image name="media_bg" extra="true">
      <pos>0.743 0.341</pos>
      <size>0.196 0.540</size>
      <zIndex>100</zIndex>
    </image>

    <image name="md_image">
      <origin>0.5 0.4</origin>
      <pos>0.19 0.225</pos>
      <maxSize>0.16 0.23</maxSize>
      <zIndex>200</zIndex>
    </image>

    <textlist name="gamelist">
      <selectorColor>33000000</selectorColor>
      <selectedColor>37d7c7</selectedColor>
      <primaryColor>ffffff</primaryColor>
      <secondaryColor>08304f</secondaryColor>
      <fontPath>./_inc/fonts/NESCyrillic_gamelist.ttf</fontPath>
      <fontSize>0.032</fontSize>
      <lineSpacing>1.75</lineSpacing>
      <alignment>left</alignment>
      <size>0.30 0.42</size>
      <pos>0.04 0.409999999999999999</pos>
    </textlist>

    <text name="md_lbl_rating, md_lbl_lastplayed">
      <color>50b8f8</color>
      <fontPath>./_inc/fonts/NESCyrillic_gamelist.ttf</fontPath>
      <fontSize>.04</fontSize>
    </text>

    <text name="md_lbl_releasedate, md_lbl_developer, md_lbl_publisher, md_lbl_genre, md_lbl_players, md_lbl_playcount, lbl_description, lbl_media">
      <color>6fa3c4</color>
      <fontPath>./_inc/fonts/NESCyrillic_gamelist.ttf</fontPath>
      <fontSize>0.020</fontSize>
      <forceUppercase>1</forceUppercase>
    </text>

    <text name="md_developer, md_publisher, md_genre, md_players, md_playcount, md_description">
      <color>c8d0df</color>
      <fontPath>./_inc/fonts/NESCyrillic_gamelist.ttf</fontPath>
      <fontSize>.025</fontSize>
    </text>

    <text name="md_lbl_rating"><pos>0.37 0.14</pos></text>

    <rating name="md_rating">
      <filledPath>./_inc/images/rating_thumb_full.png</filledPath>
      <unfilledPath>./_inc/images/rating_thumb_empty.png</unfilledPath>
      <pos>0.52 0.14</pos>
      <size>0.11 0.045</size>
    </rating>

    <text name="md_lbl_lastplayed"><pos>0.69 0.14</pos></text>

    <datetime name="md_lastplayed">
      <color>a0cf08</color>
      <fontPath>./_inc/fonts/NESCyrillic_gamelist.ttf</fontPath>
      <fontSize>0.03</fontSize>
      <pos>0.80 0.14</pos>
    </datetime>

    <text name="md_lbl_developer"><pos>0.37 0.20</pos></text>
    <text name="md_developer"><pos>0.48 0.20</pos><size>0.20 0.03</size></text>

    <text name="md_lbl_publisher"><pos>0.37 0.24</pos></text>
    <text name="md_publisher"><pos>0.48 0.24</pos><size>0.20 0.03</size></text>

    <text name="md_lbl_releasedate"><pos>0.37 0.28</pos></text>
    <datetime name="md_releasedate">
      <color>c4d4dc</color>
      <fontSize>.025</fontSize>
      <fontPath>./_inc/fonts/NESCyrillic_gamelist.ttf</fontPath>
      <pos>0.48 0.28</pos>
    </datetime>

    <text name="md_lbl_playcount"><pos>0.69 0.20</pos></text>
    <text name="md_playcount"><pos>0.80 0.20</pos><size>0.12 0.03</size></text>

    <text name="md_lbl_genre"><pos>0.69 0.24</pos></text>
    <text name="md_genre"><pos>0.80 0.24</pos><size>0.12 0.01</size></text>

    <text name="md_lbl_players"><pos>0.69 0.28</pos></text>
    <text name="md_players">
      <pos>0.80 0.28</pos>
      <size>0.12 0.03</size>
      <fontPath>./_inc/fonts/player_font4.ttf</fontPath>
    </text>

    <text name="lbl_description" extra="true"><pos>0.366 0.346</pos><text>Description</text></text>

    <text name="md_description">
      <pos>0.366 0.386</pos>
      <size>0.35 0.47</size>
      <alignment>left</alignment>
      <forceUppercase>0</forceUppercase>
      <lineSpacing>1.25</lineSpacing>
    </text>

    <text name="lbl_media" extra="true"><pos>0.748 0.346</pos><text>Screenshots</text></text>

    <image name="ss_no_image_1" extra="true">
      <origin>0 0</origin>
      <pos>0.748 0.386</pos>
      <size>0.186 0.235</size>
      <path>./_inc/images/bg_color.png</path>
      <color>50b8f80c</color>
    </image>

    <image name="ss_no_image_2" extra="true">
      <origin>0 0</origin>
      <pos>0.748 0.636</pos>
      <maxSize>0.186 0.235</maxSize>
      <path>./_inc/images/bg_color.png</path>
      <color>50b8f80c</color>
    </image>

  </view>

  <view name="video">
    <video name="md_video">
      <origin>0 0</origin>
      <pos>0.748 0.386</pos>
      <maxSize>0.186 0.235</maxSize>
      <delay>5</delay>
      <showSnapshotNoVideo>true</showSnapshotNoVideo>
      <showSnapshotDelay>true</showSnapshotDelay>
    </video>
  </view>

 <view name="grid">

  <!-- Fondo por sistema -->
  <image name="background" extra="true">
    <pos>0 0</pos>
    <size>1 1</size>
    <path>./_inc/images/wallpaper.jpg</path>
    <zIndex>0</zIndex>
  </image>

  <!-- Deco encima del fondo -->
  <image name="gamelist_deco" extra="true">
    <origin>0 0</origin>
    <pos>0 0</pos>
    <size>1 1</size>
    <path>./_inc/images/main1.png</path>
    <zIndex>10</zIndex>
  </image>

  <!-- Fondo metadata inferior -->
  <image name="bg_metadata" extra="true">
    <path>./_inc/images/bg_metadata.png</path>
    <origin>0.5 0.3</origin>
    <size>0 0.1</size>
    <pos>0.5 0.77</pos>
    <zIndex>2</zIndex>
  </image>

  <!-- Barra central -->
  <image name="carousel_bar" extra="true">
    <path>./_inc/images/carousel_bar.png</path>
    <origin>0.5 0</origin>
    <size>0 0.4814814814814815</size>
    <pos>0.5 0.2185185185185185</pos>
    <zIndex>0</zIndex>
  </image>

  <!-- Grid -->
  <imagegrid name="gamegrid">
    <pos>0.05 0.37</pos>
    <size>0.95 0.26</size>
    <scrollDirection>horizontal</scrollDirection>
    <centerSelection>true</centerSelection>
    <scrollLoop>true</scrollLoop>
    <animate>true</animate>
    <autoLayout>7 1</autoLayout>
    <autoLayoutSelectedZoom>1.30</autoLayoutSelectedZoom>
    <margin>0.018 0.025</margin>
    <zIndex>200</zIndex>
  </imagegrid>

  <!-- Tile normal -->
  <gridtile name="default">
    <size>0.22 0.22</size>
    <padding>0.01 0.01</padding>
    <backgroundImage>./_inc/icons/default.png</backgroundImage>
    <backgroundCornerSize>0.0 0.0</backgroundCornerSize>
    <backgroundColor>FFFFFFFF</backgroundColor>
    <imageColor>FFFFFFFF</imageColor>
  </gridtile>

  <!-- Tile seleccionado -->
  <gridtile name="selected">
    <size>0.26 0.26</size>
    <backgroundImage>./_inc/icons/selected.png</backgroundImage>
    <imageColor>FFFFFFFF</imageColor>
  </gridtile>

  <!-- Tipografía base para labels del metadata -->
  <text name="md_lbl_rating, md_lbl_lastplayed, md_lbl_players, md_lbl_developer, md_lbl_genre">
    <fontPath>./_inc/fonts/NESCyrillic_gamelist.ttf</fontPath>
    <fontSize>0.020</fontSize>
    <color>f8f8f8</color>
    <zIndex>12</zIndex>
  </text>

  <!-- Título -->
  <text name="md_name">
    <pos>0.32 0.233</pos>
    <size>0.30 0.03</size>
    <fontSize>0.038</fontSize>
    <fontPath>./_inc/fonts/NESCyrillic_gamelist.ttf</fontPath>
    <color>FFFFFFFF</color>
    <zIndex>12</zIndex>
  </text>

  <!-- Rating -->
  <text name="md_lbl_rating">
    <pos>0.10 0.745</pos>
  </text>

  <rating name="md_rating">
    <filledPath>./_inc/images/rating_thumb_full.png</filledPath>
    <unfilledPath>./_inc/images/rating_thumb_empty.png</unfilledPath>
    <color>FF0000</color>
    <pos>0.098 0.786</pos>
    <size>0.06 0.036</size>
    <zIndex>12</zIndex>
  </rating>

  <!-- Última vez -->
  <text name="md_lbl_lastplayed">
    <pos>0.22 0.76</pos>
  </text>

  <datetime name="md_lastplayed">
    <pos>0.22 0.78</pos>
    <fontSize>0.020</fontSize>
    <fontPath>./_inc/fonts/NESCyrillic_gamelist.ttf</fontPath>
    <color>f8f8f8</color>
    <zIndex>12</zIndex>
  </datetime>

  <!-- Players -->
  <text name="md_lbl_players">
    <pos>0.31 0.76</pos>
  </text>

  <text name="md_players">
    <pos>0.31 0.78</pos>
    <size>0.06 0.035</size>
    <fontSize>0.020</fontSize>
    <fontPath>./_inc/fonts/player_font4.ttf</fontPath>
    <color>ffffff</color>
    <zIndex>12</zIndex>
  </text>

  <!-- Developer -->
  <text name="md_lbl_developer">
    <pos>0.42 0.74</pos>
  </text>

  <text name="md_developer">
    <pos>0.42 0.78</pos>
    <size>0.22 0.03</size>
    <fontSize>0.030</fontSize>
    <fontPath>./_inc/fonts/NESCyrillic_gamelist.ttf</fontPath>
    <color>0faa9c</color>
    <zIndex>12</zIndex>
  </text>

  <!-- Genre -->
  <text name="md_lbl_genre">
    <pos>0.69 0.74</pos>
  </text>

  <text name="md_genre">
    <pos>0.655 0.78</pos>
    <size>0.24 0.03</size>
    <fontSize>0.030</fontSize>
    <fontPath>./_inc/fonts/NESCyrillic_gamelist.ttf</fontPath>
    <color>42acf6</color>
    <zIndex>12</zIndex>
  </text>

</view>
  <!-- z-index feature (tu bloque original) -->
  <feature supported="z-index">
    <view name="video">
      <image name="background"><zIndex>1</zIndex></image>
      <image name="md_marquee"><zIndex>50</zIndex></image>
      <video name="md_video"><zIndex>20</zIndex></video>
    </view>
    <view name="detailed">
      <image name="background" extra="true"><zIndex>1</zIndex></image>
    </view>
    <view name="video, detailed">
      <image name="background_system_image" extra="true"><zIndex>2</zIndex></image>
      <image name="logo_background" extra="true"><zIndex>2</zIndex></image>
      <image name="no_image_bg" extra="true"><zIndex>5</zIndex></image>
      <image name="meta_bg_top" extra="true"><zIndex>5</zIndex></image>
      <image name="meta_bg_bottom" extra="true"><zIndex>5</zIndex></image>
      <image name="description_bg_outline, media_bg_outline" extra="true"><zIndex>5</zIndex></image>
      <image name="description_bg, media_bg" extra="true"><zIndex>6</zIndex></image>
      <image name="md_image"><zIndex>6</zIndex></image>
      <text name="md_lbl_rating, md_lbl_developer, md_lbl_publisher, md_lbl_genre, md_lbl_players, md_lbl_playcount, md_lbl_releasedate, md_lbl_lastplayed, md_developer, md_publisher, md_genre, md_players, md_playcount, md_description">
        <zIndex>40</zIndex>
      </text>
      <rating name="md_rating"><zIndex>40</zIndex></rating>
      <datetime name="md_releasedate, md_lastplayed"><zIndex>40</zIndex></datetime>
    </view>
  </feature>

</theme>
